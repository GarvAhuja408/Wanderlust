<% layout("/layouts/boilerplate") %>

<div class="row">
    <div class="col-8 offset-3">
        <h3><%= listing.title %></h3>
    </div>

    <div class="card col-6 offset-3 show-card listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-image" alt="listing_image">

        <div class="card-body">
            <p class="card-text">
                <%= listing.owner.username %><br><br>
                <%= listing.description %><br>
                &#8377;<%= listing.price.toLocaleString("en-IN") %><br>
                <%= listing.location %><br>
                <%= listing.country %><br>
            </p>
        </div>
    </div>
</div>

<!-- OWNER BUTTONS -->
<% if(currUser && currUser._id.equals(listing.owner._id)) { %>
<div class="btns col-8 offset-3 mt-3">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>
    &nbsp; &nbsp;
    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
        <button class="btn btn-dark">Delete</button>
    </form>
</div>
<% } %>

<!-- MAP SECTION (FIXED) -->
<div class="col-8 offset-3 mb-3 mt-4">
    <h3>Where you will be</h3>
    <div id="map" style="width: 100%; height: 400px;"></div>
</div>

<!-- REVIEW FORM -->
<% if(currUser) { %>
<div class="col-8 offset-3 mb-3">
    <hr>
    <h4>Leave a Review</h4>

    <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">

        <label for="rating" class="form-label">Rating</label>

        <fieldset class="starability-slot mb-3">

            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked />
            
            <input type="radio" id="second-rate1" name="review[rating]" value="1" />
            <label for="second-rate1">1 star</label>

            <input type="radio" id="second-rate2" name="review[rating]" value="2" />
            <label for="second-rate2">2 stars</label>

            <input type="radio" id="second-rate3" name="review[rating]" value="3" />
            <label for="second-rate3">3 stars</label>

            <input type="radio" id="second-rate4" name="review[rating]" value="4" />
            <label for="second-rate4">4 stars</label>

            <input type="radio" id="second-rate5" name="review[rating]" value="5" />
            <label for="second-rate5">5 stars</label>

        </fieldset>

        <div class="mb-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea name="review[comment]" id="comment" class="form-control" rows="5" required></textarea>
            <div class="invalid-feedback">Please add comments for review</div>
        </div>

        <button class="btn btn-outline-dark">Submit</button>
    </form>
</div>
<% } %>

<!-- REVIEWS -->
<div class="col-8 offset-3">
    <hr>
    <p><b>All reviews</b></p>

    <div class="row">
        <% for(review of listing.reviews) { %>
            <div class="card col-5 ms-3 mb-3">
                <div class="card-body">
                    <h5 class="card-title"><%= review.author.username %></h5>

                    <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>

                    <p class="card-text"><%= review.comment %></p>
                </div>

                <form class="mb-3"
                      method="POST"
                      action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-dark">Delete</button>
                </form>
            </div>
        <% } %>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

    const map = L.map('map').setView([28.6139, 77.2090], 12);

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    const marker = L.marker([28.6139, 77.2090]).addTo(map);

 

});
</script>